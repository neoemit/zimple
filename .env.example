# Frontend runtime
VITE_ZIMPLE_API_BASE_URL=http://127.0.0.1:8000

# Web mode runtime
ZIMPLE_PORT=8000
# Host interface to publish port on.
# Use 127.0.0.1 for local-only access, or 0.0.0.0 for LAN/reverse-proxy access.
ZIMPLE_PUBLISH_HOST=127.0.0.1
# Optional local host staging directory for crawl temp/profile/output data before
# copying completed .zim archives into ZIMPLE_OUTPUT_DIR.
# Recommended when ZIMPLE_OUTPUT_DIR is on CIFS/NFS.
# ZIMPLE_STAGING_DIR=/var/tmp/zimple-staging
ZIMPLE_OUTPUT_DIR=/Users/thomas/Repos/zimple/bind
ZIMPLE_DATA_DIR=./.zimple-web-data
