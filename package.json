{
  "name": "zimple",
  "private": true,
  "version": "0.1.0",
  "description": "Cross-platform desktop app that turns websites into Kiwix-compatible ZIM files",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:tauri": "tauri dev",
    "dev:web:api": "tsx watch web-api/src/index.ts",
    "start:web:api": "node web-api/dist/index.js",
    "build": "tsc -b && vite build",
    "build:web:api": "tsc -p tsconfig.web-api.json --pretty false",
    "build:web": "npm run build && npm run build:web:api",
    "build:tauri": "tauri build",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "docker:web:up": "docker compose -f docker-compose.web.yml up --build",
    "docker:web:down": "docker compose -f docker-compose.web.yml down"
  },
  "dependencies": {
    "@fastify/static": "^8.3.0",
    "@tauri-apps/api": "^2.8.0",
    "fastify": "^5.6.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tauri-apps/cli": "^2.9.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^27.0.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4",
    "vitest": "^4.0.7",
    "tsx": "^4.20.6"
  }
}
